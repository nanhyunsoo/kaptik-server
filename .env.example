# 서버 설정
HOST=0.0.0.0
PORT=3000

# 로깅
LOG_LEVEL=INFO

# CLOVA Speech (네이버 클라우드)
# https://console.ncloud.com → AI·NAVER API → CLOVA Speech → Domain
CLOVA_SPEECH_SECRET=your_clova_secret_key_here
CLOVA_SPEECH_INVOKE_URL=https://clovaspeech-gw.ncloud.com/recog/v1/stt/streaming

# DeepL 번역 API
# https://www.deepl.com/account/summary
DEEPL_API_KEY=your_deepl_api_key_here
# Free 플랜: https://api-free.deepl.com  |  Pro 플랜: https://api.deepl.com
DEEPL_API_URL=https://api-free.deepl.com
